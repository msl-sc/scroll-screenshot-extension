{"manifest_version": 3,
  "name": "Scroll Screenshot",
  "version": "1.0.0",
  "description": "Capture full-page screenshots by scrolling from the current position",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Scroll Screenshot"
  },
  "background": {
    "service_worker": "background.js"
  } }